AURALYS_APP_NAME=Auralys Backend
AURALYS_ENV=dev
AURALYS_HOST=0.0.0.0
AURALYS_PORT=8000
AURALYS_API_PREFIX=/api/auralys
POSTGRES_DSN=postgresql://auralys:auralys@localhost:5433/auralys
QDRANT_URL=http://localhost:6333
QDRANT_DOCUMENTS_COLLECTION=auralys_documents
QDRANT_MEMORY_COLLECTION=auralys_memory
EMBEDDING_DIMENSION=16
QDRANT_SEARCH_LIMIT=4
AURALYS_AUTO_SEED=true
AURALYS_LLM_BACKEND=mock
AURALYS_EMBEDDING_BACKEND=fake
AURALYS_HUMAN_VALIDATION_DEFAULT=true

# Caddy reverse proxy (docker-compose.prod.yml) — automatic Let's Encrypt HTTPS.
# AURALYS_DOMAIN must be a domain name (not a bare IP) with a DNS A record pointing at the VM.
AURALYS_DOMAIN=app.example.com
AURALYS_ACME_EMAIL=you@example.com
